<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gnome_bg">

    <!-- ═══ FOND D'ÉCRAN ═══ -->
    <ImageView
        android:id="@+id/ivPortraitWallpaper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="@drawable/wallpaper_gnome_gradient"/>

    <!-- ═══ TOP BAR GNOME ═══ -->
    <LinearLayout
        android:id="@+id/portraitTopBar"
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:background="@color/topbar_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:elevation="20dp"
        android:paddingHorizontal="10dp">

        <TextView
            android:id="@+id/tvPortraitTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="19:42"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tvPortraitDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Jeu 24 Avr"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"/>

        <!-- Fond d'écran -->
        <TextView
            android:id="@+id/btnPortraitWallpaper"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:gravity="center"
            android:text="🖼"
            android:textSize="10sp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp"/>

        <!-- Store -->
        <TextView
            android:id="@+id/btnPortraitStore"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:gravity="center"
            android:text="📦"
            android:textSize="10sp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="4dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="▲▼" android:textSize="8sp" android:textColor="@color/text_secondary"
                android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🛜" android:textSize="10sp" android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="88%" android:textSize="10sp" android:textColor="@color/text_secondary"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ SIDE LAUNCHER (Ubuntu Touch, gauche) ═══ -->
    <LinearLayout
        android:id="@+id/sideLauncherPanel"
        android:layout_width="48dp"
        android:layout_height="match_parent"
        android:layout_marginTop="22dp"
        android:background="@color/side_launcher_bg"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingVertical="8dp"
        android:elevation="16dp">

        <!-- Accueil -->
        <FrameLayout
            android:id="@+id/btnSideHome"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginBottom="2dp"
            android:background="@drawable/launcher_icon_bg_active"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                android:gravity="center" android:text="🏠" android:textSize="17sp"/>
            <View android:layout_width="3dp" android:layout_height="20dp"
                android:layout_gravity="start|center_vertical"
                android:background="@color/ubuntu_orange"/>
        </FrameLayout>

        <View android:layout_width="26dp" android:layout_height="0.5dp"
            android:background="@color/divider_color" android:layout_marginVertical="4dp"/>

        <!-- Apps épinglées dynamiques -->
        <LinearLayout
            android:id="@+id/sidelauncherPinnedContainer"
            android:layout_width="38dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"/>

        <View android:layout_width="26dp" android:layout_height="0.5dp"
            android:background="@color/divider_color" android:layout_marginVertical="4dp"/>

        <!-- 📂 Dossier → App Drawer -->
        <FrameLayout
            android:id="@+id/btnSideFolder"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/launcher_icon_bg"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                android:gravity="center" android:text="📂" android:textSize="17sp"/>
        </FrameLayout>

        <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <View android:layout_width="26dp" android:layout_height="0.5dp"
            android:background="@color/divider_color" android:layout_marginVertical="4dp"/>

        <!-- Store -->
        <FrameLayout
            android:id="@+id/btnSideStore"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/launcher_icon_bg"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                android:gravity="center" android:text="📦" android:textSize="17sp"/>
        </FrameLayout>

        <!-- Paramètres -->
        <FrameLayout
            android:id="@+id/btnSideSettings"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/launcher_icon_bg"
            android:clickable="true"
            android:focusable="true">
            <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                android:gravity="center" android:text="⚙️" android:textSize="17sp"/>
        </FrameLayout>
    </LinearLayout>

    <!-- ═══ ZONE PRINCIPALE = CANVAS VIDE POUR WIDGETS ═══ -->
    <FrameLayout
        android:id="@+id/widgetCanvas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="22dp"
        android:layout_marginStart="48dp"
        android:background="@color/transparent"
        android:longClickable="true"/>

    <!-- Indicateur de swipe bas -->
    <View android:layout_width="60dp" android:layout_height="3dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="6dp"
        android:background="@drawable/edge_hint"/>

    <!-- ═══ APP DRAWER OVERLAY (depuis bouton 📂) ═══
         S'affiche en overlay sur toute la zone (sauf side launcher et topbar).
         visibility=gone par défaut. -->
    <FrameLayout
        android:id="@+id/containerPortraitDrawer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="22dp"
        android:layout_marginStart="48dp"
        android:visibility="gone"
        android:elevation="30dp">

        <!-- Scrim cliquable -->
        <View
            android:id="@+id/portraitDrawerScrim"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/drawer_overlay_bg"/>

        <!-- Panneau drawer -->
        <FrameLayout
            android:id="@+id/portraitDrawerPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:paddingHorizontal="10dp">

                <!-- Recherche -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/search_bar_bg">
                    <TextView android:layout_width="30dp" android:layout_height="match_parent"
                        android:layout_gravity="center_vertical"
                        android:gravity="center" android:text="🔍" android:textSize="13sp"/>
                    <EditText
                        android:id="@+id/etPortraitDrawerSearch"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="32dp"
                        android:background="@null"
                        android:hint="Rechercher…"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:singleLine="true"/>
                </FrameLayout>

                <!-- Grille apps -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPortraitDrawerGrid"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:padding="2dp"/>

                <!-- WS dots -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:layout_marginVertical="8dp">
                    <View android:layout_width="14dp" android:layout_height="4dp"
                        android:background="@drawable/ws_dot_active" android:layout_marginEnd="5dp"/>
                    <View android:layout_width="6dp" android:layout_height="4dp"
                        android:background="@drawable/ws_dot_inactive" android:layout_marginEnd="5dp"/>
                    <View android:layout_width="6dp" android:layout_height="4dp"
                        android:background="@drawable/ws_dot_inactive"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

</FrameLayout>
