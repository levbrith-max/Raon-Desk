<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape : bureau GNOME Bazzite -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLandscape"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gnome_bg">

    <!-- ═══════════════════════════════════════════════
         WALLPAPER (fond radial)
    ═══════════════════════════════════════════════ -->
    <View
        android:id="@+id/gnomeWallpaper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/wallpaper_gnome_gradient" />

    <!-- ═══════════════════════════════════════════════
         DESKTOP LAYER (fenêtres flottantes)
         C'est ce bloc qui se dézoom lors de l'overview
    ═══════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/desktopWindowLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="52dp" />

    <!-- Zone bureau (pour les clics) -->
    <FrameLayout
        android:id="@+id/layoutDesktop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="52dp" />

    <!-- ═══════════════════════════════════════════════
         APP DRAWER OVERLAY (overlay + contenu)
         Le containerDrawer couvre tout MAIS la topbar reste dessus
    ═══════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/containerDrawer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="52dp"
        android:visibility="gone">

        <!-- Fond semi-transparent — le bureau reste visible derrière -->
        <View
            android:id="@+id/overlayDrawerBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/drawer_overlay_bg"
            android:alpha="0" />

        <!-- Contenu du drawer : search + grille -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardDrawerContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="0dp"
            app:cardCornerRadius="0dp"
            app:cardBackgroundColor="@color/transparent"
            app:cardElevation="0dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingTop="24dp"
                android:paddingHorizontal="24dp">

                <!-- Barre de recherche -->
                <FrameLayout
                    android:layout_width="240dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="20dp"
                    android:background="@drawable/search_bar_bg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:text="🔍"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etDrawerSearch"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginStart="36dp"
                        android:background="@null"
                        android:hint="Rechercher des applications…"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:singleLine="true"
                        android:imeOptions="actionSearch"
                        android:inputType="text" />
                </FrameLayout>

                <!-- Grille d'apps -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAppGrid"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:padding="8dp" />

                <!-- Indicateur workspaces -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="8dp">

                    <View android:layout_width="18dp" android:layout_height="4dp"
                        android:background="@drawable/ws_dot_active" android:layout_marginEnd="5dp"/>
                    <View android:layout_width="8dp" android:layout_height="4dp"
                        android:background="@drawable/ws_dot_inactive" android:layout_marginEnd="5dp"/>
                    <View android:layout_width="8dp" android:layout_height="4dp"
                        android:background="@drawable/ws_dot_inactive"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <!-- ═══════════════════════════════════════════════
         TOP BAR (toujours au-dessus, z-order maximal)
    ═══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:background="@color/topbar_bg"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:elevation="32dp"
        android:paddingHorizontal="8dp">

        <!-- Activities -->
        <TextView
            android:id="@+id/btnActivities"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:text="Activities"
            android:textColor="@color/accent_violet"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="@drawable/topbar_btn_bg"
            android:clickable="true"
            android:focusable="true" />

        <!-- Point Bazzite -->
        <View
            android:id="@+id/btnBazziteMenu"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bazzite_dot"
            android:clickable="true"
            android:focusable="true" />

        <!-- App courante -->
        <TextView
            android:id="@+id/tvCurrentApp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Bureau"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

        <!-- Horloge centrée -->
        <TextView
            android:id="@+id/tvTopbarClock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Jeu 24 Avr  19:42"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:fontFamily="monospace" />

        <!-- Tray : AppStore -->
        <ImageView
            android:id="@+id/btnAppStore"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_store"
            android:tint="@color/text_secondary"
            android:contentDescription="App Store"
            android:clickable="true"
            android:focusable="true" />

        <!-- Tray systray -->
        <LinearLayout
            android:id="@+id/layoutSystray"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="6dp"
            android:clickable="true"
            android:focusable="true">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔊" android:textSize="10sp" android:paddingEnd="3dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🛜" android:textSize="10sp" android:paddingEnd="3dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="88%" android:textColor="@color/text_secondary" android:textSize="10sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⏻" android:textSize="10sp" android:paddingStart="4dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- POPUP menu Bazzite -->
    <androidx.cardview.widget.CardView
        android:id="@+id/popupBazziteMenu"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="30dp"
        android:visibility="gone"
        android:elevation="40dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        app:cardBackgroundColor="@color/popup_bg"
        app:cardCornerRadius="10dp"
        app:cardElevation="12dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="6dp">
            <include layout="@layout/item_popup_menu_row" android:id="@+id/popupRowGaming"/>
            <include layout="@layout/item_popup_menu_row" android:id="@+id/popupRowSteam"/>
            <include layout="@layout/item_popup_menu_row" android:id="@+id/popupRowSettings"/>
            <include layout="@layout/item_popup_menu_row" android:id="@+id/popupRowStore"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- POPUP systray -->
    <androidx.cardview.widget.CardView
        android:id="@+id/popupSystray"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="30dp"
        android:layout_marginTop="30dp"
        android:visibility="gone"
        android:elevation="40dp"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        app:cardBackgroundColor="@color/popup_bg"
        app:cardCornerRadius="10dp"
        app:cardElevation="12dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="10dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="RÉSEAU" android:textColor="@color/text_hint" android:textSize="8sp"
                android:letterSpacing="0.1" android:layout_marginBottom="5dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Wi-Fi · Connecté" android:textColor="@color/accent_green"
                android:textSize="10sp" android:layout_marginBottom="8dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BATTERIE" android:textColor="@color/text_hint" android:textSize="8sp"
                android:letterSpacing="0.1" android:layout_marginBottom="4dp"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="88% · En charge" android:textColor="@color/text_primary"
                android:textSize="10sp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══════════════════════════════════════════════
         TASKBAR / DASH (en bas — z-order élevé)
    ═══════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/taskbarContainer"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:background="@color/taskbar_bg"
        android:orientation="horizontal"
        android:elevation="28dp">

        <!-- Dash (apps épinglées) -->
        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_gravity="center"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            app:cardBackgroundColor="@color/dash_bg"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="6dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDash"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="@color/divider_color"
                    android:layout_marginHorizontal="4dp" />

                <!-- Bouton overview (⠿) -->
                <TextView
                    android:id="@+id/btnOverview"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:text="⠿"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/dash_icon_bg"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</FrameLayout>
