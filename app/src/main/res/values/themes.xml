<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.GnomeBazzite" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">@color/accent_violet</item>
        <item name="colorPrimaryVariant">@color/gnome_bg</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorSurface">@color/gnome_bg</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/gnome_bg</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>
